{
  "name": "founded-node-backend-migration",
  "version": "0.1.0",
  "private": true,
  "description": "Isolated Phase 1 Express backend skeleton for the Founded migration.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dataset:preview": "node scripts/importDataset.js preview",
    "dataset:import": "node scripts/importDataset.js import",
    "dataset:verify": "node scripts/verifyDataset.js",
    "projection-payloads:preview": "node scripts/migrateProjectionPayloads.js preview",
    "projection-payloads:migrate": "node scripts/migrateProjectionPayloads.js migrate",
    "projection-payloads:verify": "node scripts/verifyProjectionPayloads.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^9.6.3"
